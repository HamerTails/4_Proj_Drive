# SUPFile - exemple de configuration d'environnement
# Copier ce fichier en .env et remplir les valeurs avant `docker compose up`.

# Connexion PostgreSQL (depuis le conteneur api, le hostname est `db`)
# Le user/password/dbname doivent matcher les variables POSTGRES_* ci-dessous.
POSTGRES_DB=supfile
POSTGRES_USER=supfile
POSTGRES_PASSWORD=change_me_avec_openssl_rand_base64_24
DATABASE_URL=postgresql://supfile:change_me_avec_openssl_rand_base64_24@db:5432/supfile

# Cle de signature JWT - generer avec : openssl rand -hex 32
JWT_SECRET=replace_with_a_64_chars_random_string

# Google OAuth 2.0 - obtenir via https://console.cloud.google.com/apis/credentials
OAUTH_CLIENT_ID=your_google_oauth_client_id
OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
OAUTH_SUCCESS_REDIRECT=http://localhost:3001/login

# Quota par utilisateur en octets (defaut : 30 Go = 32212254720)
# Pour VPS demo avec disque limite : 1 Go = 1073741824
QUOTA_BYTES=32212254720
